# Server Binding Configurations
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# CORS Configuration (comma-separated list of allowed origins)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI/Claude Integration Configurations
