def nginx_backup_restore():
    config_path = _local_nginx_config_path()
    assert config_path.exists(), f"nginx.conf not found at {config_path}"
    
    # Save original content
    original_content = config_path.read_text(encoding="utf-8")
    
    yield config_path
    
    # Restore original content
    config_path.write_text(original_content, encoding="utf-8")


def test_vulnerability_detection_and_remediation_lifecycle(nginx_backup_restore):
    config_path = nginx_backup_restore
    
    # 1. Reset Nginx to its intentionally vulnerable state
    vulnerable_nginx = """worker_processes 1;
events {
    worker_connections 1024;
}
http {
    server {
        listen 80;
        server_name localhost;

        root /usr/share/nginx/html;
        index index.html;

        location / {
            try_files $uri $uri/ =404;
        }

        # Deliberate insecure configuration for sample target
        add_header X-Powered-By "nginx";
        server_tokens on;
        ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
    }
}
"""
    config_path.write_text(vulnerable_nginx, encoding="utf-8")
    
    # 2. Run scanner on the allowlisted domain
    domain = "example.team-owned-site.com"
    scanner = ScannerService()
    
    scan_res = scanner.execute(
        domain=domain,
        profile="full-scan",
        metadata={"triggeredBy": "test"},
        dry_run=False,
        verification=False
    )
    
    # Ensure findings are generated and greater than zero
    findings = scan_res["normalizedFindings"]
    assert len(findings) > 0, "No findings detected before remediation!"
    
    # Verify scanner detects all intentionally configured vulnerabilities
    finding_titles = {f["title"] for f in findings}
    
    expected_vulns = {
        "X-Powered-By Header Exposure",
        "Nginx server_tokens Enabled",
        "Missing HTTP Strict-Transport-Security (HSTS)",
        "Missing Content-Security-Policy (CSP)",
        "Missing X-Frame-Options Header",
        "Missing X-Content-Type-Options Header",
        "Legacy TLS Protocols Enabled"
    }
    
    for vuln in expected_vulns:
        assert vuln in finding_titles, f"Vulnerability '{vuln}' was not detected by scanner."
        
    # 3. Translate findings to recommendations using AI analysis
    ai_service = AIAnalysisService()
    recon_summary = "Recon summary placeholder"
    ai_res = ai_service.generate_analysis(domain, recon_summary, findings)
    
    recommendations = ai_res["recommendations"]
    assert len(recommendations) > 0
    
    # 4. Execute remediation action
    remediation = RemediationService()
    target_details = {
        "targetDomain": domain,
        "approvalContext": {"userConfirmed": True},
        "dryRun": False,
        "verification": False
    }
    
    rem_res = remediation.execute_remediation(
        task_id="test-task-123",
        action="fix",
        recommendations=recommendations,
        target_details=target_details
    )
    
    assert rem_res["remediationStatus"] == "completed"
    assert len(rem_res["remediationActions"]) > 0
    
    # 5. Run scanner again after remediation
    post_scan_res = scanner.execute(
        domain=domain,
        profile="full-scan",
        metadata={"triggeredBy": "test-post-remediation"},
        dry_run=False,
        verification=False
    )
    
    post_findings = post_scan_res["normalizedFindings"]
    post_finding_titles = {f["title"] for f in post_findings}
    
    # Verify that the remediated vulnerabilities are resolved and no longer in findings
    for vuln in expected_vulns:
        assert vuln not in post_finding_titles, f"Vulnerability '{vuln}' was still found after remediation!"
        
    # The findings count should drop significantly (ideally to 0)
    assert len(post_findings) < len(findings)
