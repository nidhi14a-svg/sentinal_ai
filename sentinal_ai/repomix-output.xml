<file path="docker-compose.yml">
services:
  backend:
    build: .
    container_name: sentinel_ai_backend
    volumes:
      - ./backend:/app/backend
      - ./sample_target:/app/sample_target
    ports:
      - '8000:8000'
    env_file:
      - .env.example
    depends_on:
      - zap

  zap:
    image: ghcr.io/zaproxy/zaproxy:stable
    container_name: sentinel_ai_zap
    command: ["zap.sh", "-daemon", "-host", "0.0.0.0", "-port", "8080", "-config", "api.disablekey=true"]
    ports:
      - '8080:8080'
    volumes:
      - ./backend/sentinel/scanner/mock_data:/zap/mock_data

  sample_target:
    build:
      context: ./sample_target
      dockerfile: Dockerfile
    container_name: sentinel_ai_sample_target
    ports:
      - '8081:80'
    volumes:
      - ./sample_target/site:/usr/share/nginx/html:ro
      - ./sample_target/nginx.conf:/etc/nginx/nginx.conf:ro

  frontend:
    image: node:20-bullseye
    container_name: sentinel_ai_frontend
    working_dir: /app/frontend
    volumes:
      - ./frontend:/app/frontend
      - /app/frontend/node_modules
    ports:
      - '3000:3000'
    command: ["sh", "-c", "npm install && npm run dev -- --host 0.0.0.0 --port 3000"]
