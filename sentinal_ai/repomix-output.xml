                                <span className="flex items-center gap-2">
                                    DOWNLOAD PDF REPORT
                                    {isHoveringDownload && (
                                        <motion.span
                                            initial={{ opacity: 0, x: -10 }}
                                            animate={{ opacity: 1, x: 0 }}
                                            className="text-xs text-accent-cyan"
                                        >
                                            (Secure PDF)
                                        </motion.span>
                                    )}
                                </span>
